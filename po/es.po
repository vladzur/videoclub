msgstr "GTK;"

#: data/com.vladzur.videoclub.metainfo.xml.in:8
msgid "Explora, organiza y reproduce tu colección de películas"
msgstr "Explora, organiza y reproduce tu colección de películas"

#: data/com.vladzur.videoclub.metainfo.xml.in:10
msgid ""
"Videoclub es una aplicación de escritorio para GNOME que te permite "
"explorar, organizar y reproducir tu colección de películas almacenadas "
"localmente."
msgstr ""

#: data/com.vladzur.videoclub.metainfo.xml.in:14
msgid ""
"Escanea directorios del sistema de archivos, descarga metadatos y pósters "
"desde OMDb y TMDb, obtiene subtítulos desde OpenSubtitles, y reproduce video "
"usando GStreamer con aceleración por hardware."
msgstr ""

#: data/com.vladzur.videoclub.metainfo.xml.in:19
msgid "Funcionalidades principales:"
msgstr "Funcionalidades principales:"

#: data/com.vladzur.videoclub.metainfo.xml.in:21
msgid "Escaneo recursivo de directorios con detección de archivos de video"
msgstr "Escaneo recursivo de directorios con detección de archivos de video"

#: data/com.vladzur.videoclub.metainfo.xml.in:22
msgid "Vista en grilla responsiva con carátulas"
msgstr "Vista en grilla responsiva con carátulas"

#: data/com.vladzur.videoclub.metainfo.xml.in:23
msgid "Búsqueda y filtrado por título en tiempo real"
msgstr "Búsqueda y filtrado por título en tiempo real"

#: data/com.vladzur.videoclub.metainfo.xml.in:24
msgid "Descarga de metadatos, pósters y subtítulos"
msgstr "Descarga de metadatos, pósters y subtítulos"

#: data/com.vladzur.videoclub.metainfo.xml.in:25
msgid "Reproducción de video con aceleración por hardware (GStreamer)"
msgstr "Reproducción de video con aceleración por hardware (GStreamer)"

#: data/com.vladzur.videoclub.metainfo.xml.in:26
msgid "Drag &amp; drop para reproducción instantánea"
msgstr "Drag &amp; drop para reproducción instantánea"

#: data/com.vladzur.videoclub.metainfo.xml.in:27
msgid "Inhibición del protector de pantalla durante la reproducción"
msgstr "Inhibición del protector de pantalla durante la reproducción"

