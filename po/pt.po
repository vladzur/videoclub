msgid "OMDb API key"
msgstr "Chave API do OMDb"

#: data/com.vladzur.videoclub.gschema.xml:12
msgid ""
"API key for OMDb (Open Movie Database) used to fetch movie metadata and "
"posters."
msgstr ""

