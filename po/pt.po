msgid "Preferred subtitle language"
msgstr "Idioma de legendas preferido"

#: data/com.vladzur.videoclub.gschema.xml:27
msgid "ISO 639-1 language code for the preferred subtitle language."
msgstr "Código de idioma ISO 639-1 para o idioma de legendas preferido."

