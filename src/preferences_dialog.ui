<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>

  <template class="VideoclubPreferencesDialog" parent="AdwPreferencesDialog">
    <property name="title" translatable="yes">Preferences</property>
    <property name="search-enabled">False</property>

    <!-- ─── Página: APIs ─────────────────────────────────────────── -->
    <child>
      <object class="AdwPreferencesPage" id="apis_page">
        <property name="title" translatable="yes">APIs</property>
        <property name="icon-name">key-symbolic</property>

        <!-- Grupo OMDb -->
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title" translatable="yes">OMDb (Open Movie Database)</property>
            <property name="description" translatable="yes">Used to fetch movie metadata, posters, and descriptions.</property>

            <child>
              <object class="AdwPasswordEntryRow" id="omdb_key_entry">
                <property name="title" translatable="yes">API Key</property>
              </object>
            </child>

            <child>
              <object class="AdwActionRow">
                <property name="title" translatable="yes">Get a free API key</property>
                <property name="subtitle">omdbapi.com/apikey.aspx</property>
                <property name="activatable">True</property>
                <property name="action-name">prefs.open-omdb-website</property>
                <child type="suffix">
                  <object class="GtkImage">
                    <property name="icon-name">adw-external-link-symbolic</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- Grupo OpenSubtitles -->
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title" translatable="yes">OpenSubtitles</property>
            <property name="description" translatable="yes">Used to search and download subtitles for your movies.</property>

            <child>
              <object class="AdwPasswordEntryRow" id="opensubtitles_key_entry">
                <property name="title" translatable="yes">API Key</property>
              </object>
            </child>

            <child>
              <object class="AdwActionRow">
                <property name="title" translatable="yes">Get a free API key</property>
                <property name="subtitle">opensubtitles.com/consumers</property>
                <property name="activatable">True</property>
                <property name="action-name">prefs.open-opensubtitles-website</property>
                <child type="suffix">
                  <object class="GtkImage">
                    <property name="icon-name">adw-external-link-symbolic</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

      </object>
    </child>

    <!-- ─── Página: General ──────────────────────────────────────── -->
    <child>
      <object class="AdwPreferencesPage" id="general_page">
        <property name="title" translatable="yes">General</property>
        <property name="icon-name">preferences-system-symbolic</property>

        <!-- Grupo Idioma -->
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title" translatable="yes">Language</property>

            <child>
              <object class="AdwComboRow" id="subtitle_language_row">
                <property name="title" translatable="yes">Subtitle Language</property>
                <property name="model">
                  <object class="GtkStringList">
                    <items>
                      <item translatable="yes">Spanish (es)</item>
                      <item translatable="yes">English (en)</item>
                      <item translatable="yes">French (fr)</item>
                      <item translatable="yes">Portuguese (pt)</item>
                      <item translatable="yes">German (de)</item>
                      <item translatable="yes">Italian (it)</item>
                    </items>
                  </object>
                </property>
              </object>
            </child>

            <child>
              <object class="AdwComboRow" id="audio_language_row">
                <property name="title" translatable="yes">Audio Language</property>
                <property name="model">
                  <object class="GtkStringList">
                    <items>
                      <item translatable="yes">Spanish (es)</item>
                      <item translatable="yes">English (en)</item>
                      <item translatable="yes">French (fr)</item>
                      <item translatable="yes">Portuguese (pt)</item>
                      <item translatable="yes">German (de)</item>
                      <item translatable="yes">Italian (it)</item>
                    </items>
                  </object>
                </property>
              </object>
            </child>

          </object>
        </child>

      </object>
    </child>

  </template>
</interface>
