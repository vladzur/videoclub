# Videoclub — Variables de entorno de desarrollo
# Copia este archivo como .env y completa tus claves

# API key de The Movie Database (TMDb)
# Obtén la tuya gratis en: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# API key de OpenSubtitles (opcional, para descarga de subtítulos)
# https://www.opensubtitles.com/consumers
OPENSUBTITLES_API_KEY=

# Nivel de logging (trace, debug, info, warn, error)
RUST_LOG=info
