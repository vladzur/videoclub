<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.vladzur.videoclub</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Videoclub</name>
  <summary>Explora, organiza y reproduce tu colección de películas</summary>
  <description>
    <p>
      Videoclub es una aplicación de escritorio para GNOME que te permite explorar,
      organizar y reproducir tu colección de películas almacenadas localmente.
    </p>
    <p>
      Escanea directorios del sistema de archivos, descarga metadatos y pósters desde
      OMDb y TMDb, obtiene subtítulos desde OpenSubtitles, y reproduce video usando
      GStreamer con aceleración por hardware.
    </p>
    <p>Funcionalidades principales:</p>
    <ul>
      <li>Escaneo recursivo de directorios con detección de archivos de video</li>
      <li>Vista en grilla responsiva con carátulas</li>
      <li>Búsqueda y filtrado por título en tiempo real</li>
      <li>Descarga de metadatos, pósters y subtítulos</li>
      <li>Reproducción de video con aceleración por hardware (GStreamer)</li>
      <li>Drag &amp; drop para reproducción instantánea</li>
      <li>Inhibición del protector de pantalla durante la reproducción</li>
    </ul>
  </description>

  <developer id="com.vladzur">
    <name>vladzur</name>
  </developer>

  <url type="homepage">https://github.com/vladzur/videoclub</url>
  <url type="vcs-browser">https://github.com/vladzur/videoclub</url>
  <url type="bugtracker">https://github.com/vladzur/videoclub/issues</url>
  <url type="contribute">https://github.com/vladzur/videoclub</url>

  <translation type="gettext">videoclub</translation>
  <!-- All graphical applications having a desktop file must have this tag in the MetaInfo.
     If this is present, appstreamcli compose will pull icons, keywords and categories from the desktop file. -->
  <launchable type="desktop-id">com.vladzur.videoclub.desktop</launchable>
  <!-- Use the OARS website (https://hughsie.github.io/oars/generate.html) to generate these and make sure to use oars-1.1 -->
  <content_rating type="oars-1.1" />

  <!-- Applications should set a brand color in both light and dark variants like so -->
  <branding>
    <color type="primary" scheme_preference="light">#ff00ff</color>
    <color type="primary" scheme_preference="dark">#993d3d</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://example.org/example1.png</image>
      <caption>A caption</caption>
    </screenshot>
    <screenshot>
      <image>https://example.org/example2.png</image>
      <caption>A caption</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="1.4.0" date="2026-06-08">
      <url type="details">https://github.com/vladzur/videoclub/releases/tag/v1.4.0</url>
      <description translate="no">
        <p>Nueva funcionalidad de gestión de biblioteca.</p>
        <ul>
          <li>Nuevo botón "Limpiar biblioteca" en Preferencias para reiniciar la colección desde cero.</li>
          <li>Diálogo de confirmación para evitar eliminaciones accidentales.</li>
          <li>Limpieza completa de catálogo, metadatos y directorios de escaneo.</li>
          <li>Traducciones completas al español, alemán y portugués para las nuevas cadenas.</li>
        </ul>
      </description>
    </release>
    <release version="1.3.0" date="2026-06-07">
      <url type="details">https://github.com/vladzur/videoclub/releases/tag/v1.3.0</url>
      <description translate="no">
        <p>Gran actualización con importantes mejoras en gestión de metadatos, subtítulos y reproducción.</p>
        <ul>
          <li>Edición manual de metadatos de películas con almacenamiento persistente local.</li>
          <li>Nuevo visor rápido de información de películas.</li>
          <li>Nuevo motor nativo de renderizado de subtítulos, mejorando sincronización y soporte de caracteres.</li>
          <li>Detección de archivos de subtítulos más inteligente y flexible.</li>
          <li>Control de volumen funcional en el reproductor.</li>
          <li>Integración con la bandeja del sistema (System Tray) con menú contextual interactivo.</li>
          <li>Numerosas correcciones de errores en la interfaz gráfica y entorno Flatpak.</li>
        </ul>
      </description>
    </release>
    <release version="1.2.0" date="2026-06-06">
      <url type="details">https://github.com/vladzur/videoclub/releases/tag/v1.2.0</url>
      <description translate="no">
        <p>Lanzamiento inicial público de Videoclub.</p>
        <ul>
          <li>Escaneo recursivo de directorios de películas</li>
          <li>Descarga de metadatos desde OMDb y TMDb</li>
          <li>Descarga de subtítulos desde OpenSubtitles</li>
          <li>Reproducción de video con GStreamer</li>
          <li>Interfaz gráfica con libadwaita</li>
        </ul>
      </description>
    </release>
  </releases>

</component>
